# Roblox Voice Creator - Environment Variables
# =============================================
# Copy this file to .env and fill in your API keys

# OpenRouter API Key (for Claude Computer Use)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# OpenAI API Key (for Whisper voice recognition)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# Model Configuration (optional - defaults are fine)
CLAUDE_MODEL=anthropic/claude-sonnet-4-20250514
WHISPER_MODEL=whisper-1
